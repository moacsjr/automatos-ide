{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@rpa/automation-core": ["libs/automation-core/src/index.ts"],
      "@pluggable-js/core": ["libs/pluggable-core/src/index.ts"],
      "@pluggable-js/react": ["libs/pluggable-react/src/index.tsx"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },
  "exclude": ["node_modules", "dist"]
}
